---
import links from "../collections/links.json";

const title =
	"Amin N Ali — Data Scientist & Analytics Engineer in Vancouver, British Columbia";
const description =
	"Amin N Ali is a Data Scientist and Analytics Engineer based in Vancouver, British Columbia — building AI-forward data solutions and performant analytics teams.";
const keywords =
	"Amin N Ali, Data Scientist, Analytics Engineer, Vancouver, British Columbia, Canada, AI-forward data solutions, analytics engineering, data science";

// Structured data (schema.org Person) so search & AI engines can extract the key facts.
const personLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Amin N Ali",
	jobTitle: ["Data Scientist", "Analytics Engineer"],
	url: "https://aminn.ca",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Vancouver",
		addressRegion: "British Columbia",
		addressCountry: "CA",
	},
	sameAs: [
		"https://www.linkedin.com/in/aminnali/",
		"https://instagram.com/aminn04",
		"https://open.spotify.com/user/aminn04",
		"https://github.com/aminn04",
	],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Amin N Ali" />
    <meta name="robots" content="index, follow" />

    <!-- Structured data for search & AI engines -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Amin N Ali" />
    <meta property="og:url" content="https://aminn.ca/" />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:image" content="/assets/images/cover.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/assets/images/cover.png" />

    <!-- Apply dark mode before paint to avoid flicker -->
    <script is:inline>
      if (
        typeof Storage !== "undefined" &&
        localStorage.getItem("dark_mode") === "true"
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      html {
        color-scheme: light dark;
        -webkit-text-size-adjust: 100%;
      }
      html.dark {
        color-scheme: dark;
      }
      body {
        -webkit-overflow-scrolling: touch;
      }
      @supports (padding: env(safe-area-inset-top)) {
        body {
          padding-left: env(safe-area-inset-left);
          padding-right: env(safe-area-inset-right);
          padding-bottom: env(safe-area-inset-bottom);
        }
      }
      @keyframes flip-horizontal {
        0% {
          transform: rotateY(0deg);
        }
        100% {
          transform: rotateY(360deg);
        }
      }
      .logo-flip:hover svg {
        animation: flip-horizontal 1s linear infinite;
      }
    </style>
  </head>

  <body
    class="relative min-h-screen font-sans antialiased text-pnw-sea-900 dark:text-pnw-sea-100"
  >
    <!-- Animated clouds background — fills the viewport, sits behind the column.
         Only visible in the margins beside the column (on larger screens). -->
    <div
      id="vanta-bg"
      class="fixed inset-0 -z-10 bg-gradient-to-b from-sky-200 to-pnw-sea-300 dark:from-pnw-sea-950 dark:to-pnw-sea-800"
    >
    </div>

    <!-- The whole site lives in this single centered column -->
    <main
      class="relative z-10 mx-auto flex min-h-screen w-full max-w-md flex-col items-center bg-gradient-to-b from-pnw-sea-50 via-white to-pnw-sea-100 px-6 pb-10 shadow-2xl shadow-pnw-sea-900/10 dark:from-slate-950 dark:via-slate-950 dark:to-pnw-sea-950 dark:shadow-black/40"
    >
      <!-- Top bar: logo + dark-mode switch (kept inside the column) -->
      <div class="flex w-full items-center justify-between pt-5">
        <!-- Logo -->
        <a
          href="/"
          aria-label="Home"
          class="logo-flip group flex items-center [perspective:400px]"
        >
      <svg
        class="w-10 h-10 transition-transform duration-300"
        viewBox="0 0 48 48"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <!-- Outer hexagon frame -->
        <path
          d="M24 2L44 14V34L24 46L4 34V14L24 2Z"
          class="stroke-pnw-sea-500 dark:stroke-pnw-sea-400 fill-pnw-sea-500/10 dark:fill-pnw-sea-400/10"
          stroke-width="1.5"
        />
        <!-- Inner geometric accent -->
        <path
          d="M24 8L38 16V32L24 40L10 32V16L24 8Z"
          class="stroke-pnw-sea-500/60 dark:stroke-pnw-sea-400/60"
          stroke-width="0.75"
          fill="none"
        />
        <!-- First A - left -->
        <path
          d="M14 32L20 16L26 32M16 27H24"
          class="stroke-pnw-sea-500 dark:stroke-pnw-sea-400"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <!-- Second A - right, slightly overlapping -->
        <path
          d="M22 32L28 16L34 32M24 27H32"
          class="stroke-pnw-sea-500/60 dark:stroke-pnw-sea-400/60"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <!-- Futuristic accent dots -->
        <circle cx="24" cy="6" r="1.5" class="fill-pnw-sea-500 dark:fill-pnw-sea-400" />
        <circle cx="24" cy="42" r="1.5" class="fill-pnw-sea-500 dark:fill-pnw-sea-400" />
      </svg>
    </a>

        <!-- Dark mode switch -->
        <button
          id="darkToggle"
          type="button"
          aria-label="Toggle dark mode"
          class="flex items-center cursor-pointer"
        >
          <span
            class="relative block w-5 h-8 rounded-sm border-2 border-pnw-sea-500/40 dark:border-pnw-sea-400/40 bg-pnw-sea-500/15 dark:bg-pnw-sea-400/15 shadow-inner"
          >
            <span
              class="absolute left-0.5 right-0.5 h-3 rounded-sm bg-pnw-sea-500 dark:bg-pnw-sea-400 shadow-md transition-all duration-300 ease-out top-[calc(100%-14px)] dark:top-0.5"
            ></span>
          </span>
        </button>
      </div>

      <!-- Avatar: near-square frame (slightly tall so less of the portrait is cropped) -->
      <img
        src="/assets/images/photo.png"
        alt="Amin N Ali"
        width="320"
        height="384"
        loading="eager"
        decoding="async"
        class="object-cover object-top w-64 sm:w-72 aspect-[5/6] rounded-2xl border border-pnw-sea-200 shadow-sm dark:border-pnw-sea-800 mt-8 sm:mt-10"
      />

      <!-- Identity -->
      <h1 class="mt-5 font-display text-4xl font-black tracking-tight text-pnw-sea-800 dark:text-pnw-sea-100">
        Amin N Ali
      </h1>
      <p class="mt-1 text-center font-display text-sm font-medium text-pnw-sea-800 dark:text-pnw-sea-100">
        Data Scientist
        <span class="mx-1 text-pnw-sea-300 dark:text-pnw-sea-700">·</span>
        Analytics Engineer
        <br />
        <span class="text-xs font-normal italic text-pnw-sea-800 dark:text-pnw-sea-100">
          Vancouver
          <span class="mx-1 not-italic text-pnw-sea-300 dark:text-pnw-sea-700">·</span>
          British Columbia
        </span>
      </p>
      <p class="max-w-xs mt-3 text-sm text-center text-pnw-sea-600 dark:text-pnw-sea-300">
        I build AI-forward data solutions and performant analytics teams.
      </p>

      <!-- Social icons: outlined square cards, styled like the link boxes -->
      <nav
        aria-label="Social links"
        class="flex items-center justify-center gap-3 mt-6"
      >
        <a
          href="mailto:aminali@fastmail.com"
          class="grid h-12 w-12 place-items-center rounded-2xl border border-pnw-sea-200 bg-white/70 text-red-500 shadow-sm backdrop-blur-sm transition hover:-translate-y-0.5 hover:border-pnw-sea-300 hover:bg-white hover:shadow-md dark:border-pnw-sea-800 dark:bg-pnw-sea-900/40 dark:hover:border-pnw-sea-600 dark:hover:bg-pnw-sea-900"
        >
          <span class="sr-only">Email</span>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10" />
            <path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/aminnali/"
          target="_blank"
          rel="noopener"
          class="grid h-12 w-12 place-items-center rounded-2xl border border-pnw-sea-200 bg-white/70 text-[#0A66C2] shadow-sm backdrop-blur-sm transition hover:-translate-y-0.5 hover:border-pnw-sea-300 hover:bg-white hover:shadow-md dark:border-pnw-sea-800 dark:bg-pnw-sea-900/40 dark:hover:border-pnw-sea-600 dark:hover:bg-pnw-sea-900"
        >
          <span class="sr-only">LinkedIn</span>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M8 11v5" />
            <path d="M8 8v.01" />
            <path d="M12 16v-5" />
            <path d="M16 16v-3a2 2 0 1 0 -4 0" />
            <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10" />
          </svg>
        </a>
        <a
          href="https://instagram.com/aminn04"
          target="_blank"
          rel="noopener"
          class="grid h-12 w-12 place-items-center rounded-2xl border border-pnw-sea-200 bg-white/70 text-[#E4405F] shadow-sm backdrop-blur-sm transition hover:-translate-y-0.5 hover:border-pnw-sea-300 hover:bg-white hover:shadow-md dark:border-pnw-sea-800 dark:bg-pnw-sea-900/40 dark:hover:border-pnw-sea-600 dark:hover:bg-pnw-sea-900"
        >
          <span class="sr-only">Instagram</span>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 8a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4l0 -8" />
            <path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" />
            <path d="M16.5 7.5v.01" />
          </svg>
        </a>
        <a
          href="https://open.spotify.com/user/aminn04"
          target="_blank"
          rel="noopener"
          class="grid h-12 w-12 place-items-center rounded-2xl border border-pnw-sea-200 bg-white/70 text-[#1DB954] shadow-sm backdrop-blur-sm transition hover:-translate-y-0.5 hover:border-pnw-sea-300 hover:bg-white hover:shadow-md dark:border-pnw-sea-800 dark:bg-pnw-sea-900/40 dark:hover:border-pnw-sea-600 dark:hover:bg-pnw-sea-900"
        >
          <span class="sr-only">Spotify</span>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
            <path d="M8 11.973c2.5 -1.473 5.5 -.973 7.5 .527" />
            <path d="M9 15c1.5 -1 4 -1 5 .5" />
            <path d="M7 9c2 -1 6 -2 10 .5" />
          </svg>
        </a>
      </nav>

      <!-- Link buttons -->
      <div class="flex flex-col w-full gap-3 mt-9">
        {
          links.map((link) => (
            <a
              href={link.url}
              target={link.url.startsWith("http") ? "_blank" : undefined}
              rel={link.url.startsWith("http") ? "noopener" : undefined}
              class="group flex items-center gap-4 w-full px-5 py-4 rounded-2xl border border-pnw-sea-200 bg-white/70 backdrop-blur-sm shadow-sm transition hover:-translate-y-0.5 hover:border-pnw-sea-300 hover:bg-white hover:shadow-md dark:border-pnw-sea-800 dark:bg-pnw-sea-900/40 dark:hover:border-pnw-sea-600 dark:hover:bg-pnw-sea-900"
            >
              <span class="text-2xl leading-none shrink-0">{link.icon}</span>
              <span class="flex flex-col min-w-0">
                <span class="text-sm font-semibold text-pnw-sea-800 dark:text-pnw-sea-100">
                  {link.title}
                </span>
                <span class="text-xs truncate text-pnw-sea-500 dark:text-pnw-sea-400">
                  {link.subtitle}
                </span>
              </span>
              <svg
                class="w-4 h-4 ml-auto shrink-0 text-pnw-sea-400 transition group-hover:translate-x-0.5 group-hover:text-pnw-sea-600 dark:group-hover:text-pnw-sea-300"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))
        }
      </div>

      <!-- Footer -->
      <footer class="mt-auto pt-10">
        <p
          class="font-mono text-[11px] font-semibold uppercase tracking-[0.05em] text-pnw-stone-400"
        >
          🇨🇦 © {new Date().getFullYear()} Amin N Ali
        </p>
      </footer>
    </main>

    <!-- Animated background (Vanta.js): sunny clouds in light, moody fog in dark -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/three@0.134.0/build/three.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.clouds.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>
    <script is:inline>
      // Build the background effect for the current theme.
      // Light = bright & sunny clouds · Dark = dark, moody fog.
      function buildVanta() {
        if (window.vantaEffect) {
          window.vantaEffect.destroy();
          window.vantaEffect = null;
        }
        const dark = document.documentElement.classList.contains("dark");
        const base = {
          el: "#vanta-bg",
          mouseControls: true,
          touchControls: true,
          gyroControls: false,
          minHeight: 200.0,
          minWidth: 200.0,
        };
        if (dark) {
          if (!(window.VANTA && window.VANTA.FOG)) return;
          window.vantaEffect = window.VANTA.FOG({
            ...base,
            blurFactor: 0.6,
            speed: 1.4,
            zoom: 1.0,
            highlightColor: 0x1f4a8a,
            midtoneColor: 0x152f5c,
            lowlightColor: 0x0d1d3a,
            baseColor: 0x070f1f,
          });
        } else {
          if (!(window.VANTA && window.VANTA.CLOUDS)) return;
          window.vantaEffect = window.VANTA.CLOUDS({
            ...base,
            speed: 0.9,
            backgroundColor: 0xffffff,
            skyColor: 0x3b7dd8,
            cloudColor: 0xffffff,
            cloudShadowColor: 0x9fb8d4,
            sunColor: 0xffd633,
            sunGlareColor: 0xffb84d,
            sunlightColor: 0xffcc66,
          });
        }
      }

      buildVanta();

      // Dark-mode toggle — persists preference and swaps the background effect
      document.getElementById("darkToggle").addEventListener("click", () => {
        const root = document.documentElement;
        if (root.classList.toggle("dark")) {
          localStorage.setItem("dark_mode", "true");
        } else {
          localStorage.removeItem("dark_mode");
        }
        buildVanta();
      });
    </script>
  </body>
</html>
